{
  "name": "afformative",
  "version": "0.6.3",
  "description": "A standardized way to format values in your React components.",
  "keywords": [
    "react",
    "component",
    "components",
    "formatting",
    "formatter",
    "formatters",
    "format",
    "moment",
    "react-intl",
    "entity",
    "enum",
    "arbitrary",
    "value",
    "values"
  ],
  "repository": "https://github.com/wafflepie/afformative",
  "license": "MIT",
  "contributors": [
    "Vaclav Jancarik <hi@wafflepie.dev>"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp",
    "test": "pnpm test:prettier && pnpm run test:typescript && pnpm run test:eslint && pnpm run test:vitest",
    "test:eslint": "eslint src",
    "test:prettier": "prettier --check src",
    "test:typescript": "tsc --noEmit",
    "test:vitest": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "publishConfig": {
    "access": "public"
  }
}
